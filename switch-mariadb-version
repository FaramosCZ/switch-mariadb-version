#!/bin/bash

# MariaDB version switch script - configurable version switching
# Usage: switch-mariadb-version <source_version> <target_version>

set -euo pipefail

# Function to display usage
usage() {
    cat << EOF
Usage: $0 <source_version> <target_version>

Examples:
  $0 10.11 11.8

Description:
  Switches MariaDB packages shipped in the standard repositories
  of Fedora, CentOS Stream and RHEL from source version to target version.

  Lists installed packages, maps to target versions, and runs DNF install.
EOF
    exit 1
}

# Function to validate version format
validate_version() {
    local version="${1:-}"
    if [[ ! $version =~ ^[0-9]+\.[0-9]+$ ]]; then
        echo "Error: Version must be in format NUMBER.NUMBER (e.g., 10.11)" >&2
        exit 1
    fi
}

# Function to check if source packages exist
check_source_packages() {
    local source_version="${1:-}"
    echo "Checking for MariaDB $source_version packages..."

    # Get installed packages
    local rpm_output
    rpm_output=$(rpm -qa 2>/dev/null)
    local source_packages
    # Use grep with || true to avoid pipefail issues when no matches found
    source_packages=$(echo "$rpm_output" | grep -E "^mariadb.*-${source_version}" || true)

    # Check if we found any packages (handle empty result correctly)
    if [ -z "$source_packages" ]; then
        echo "Error: No MariaDB $source_version packages found installed" >&2
        exit 1
    fi

    # Display packages sorted, one per line
    local sorted_packages
    sorted_packages=$(echo "$source_packages" | sort)
    local package_count
    package_count=$(echo "$source_packages" | wc -l)
    echo "Found $package_count MariaDB $source_version installed packages:"
    while IFS= read -r package; do
        echo "  $package"
    done <<< "$sorted_packages"
    echo
}

# Function to generate target package list
generate_target_packages() {
    local source_version="${1:-}"
    local target_version="${2:-}"

    local source_packages
    # Use grep with || true to avoid pipefail issues when no matches found
    source_packages=$(rpm_output=$(rpm -qa); echo "$rpm_output" | grep -E "^mariadb.*-${source_version}" | sed -E "s/-${source_version}.*//; s/^mariadb[0-9.]*/mariadb/" | sort -u || true)

    if [ -z "$source_packages" ]; then
        echo "Error: No MariaDB $source_version packages found" >&2
        exit 1
    fi

    local target_packages=""
    while IFS= read -r package; do
        local target_package
        target_package=${package/mariadb/mariadb${target_version}}
        target_packages="$target_packages $target_package"
    done <<< "$source_packages"

    echo "$target_packages"
}

# Main function
main() {

    # Check arguments
    if [ $# -ne 2 ]; then
        echo "Error: Exactly 2 arguments required" >&2
        usage
    fi

    # Show help if requested
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        usage
    fi

    local source_version="$1"
    local target_version="$2"

    # Check for empty arguments
    if [ -z "$source_version" ] || [ -z "$target_version" ]; then
        echo "Error: Both source and target versions must be non-empty" >&2
        usage
    fi

    echo "MariaDB Version Switch: $source_version -> $target_version"
    echo "======================================================"

    # Validate version formats
    validate_version "$source_version"
    validate_version "$target_version"

    # Check source packages exist
    check_source_packages "$source_version"

    # Generate target package list
    local target_packages
    target_packages=$(generate_target_packages "$source_version" "$target_version")

    # Trim leading space and display target packages one per line
    target_packages=${target_packages# }
    echo "Composing list of packages to be installed:"
    # Convert space-separated list to array for safe iteration
    local -a package_array
    read -ra package_array <<< "$target_packages"
    for package in "${package_array[@]}"; do
        echo "   $package"
    done
    echo
    echo "Ready to switch MariaDB packages."
    echo
    echo "This will run:"
    echo "  dnf install --allowerasing $target_packages"
    read -p "Continue with version switch? (y/N): " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Starting MariaDB version switch..."
        # shellcheck disable=SC2086 # We want word splitting for package names
        dnf install --allowerasing $target_packages
        exit $?
    else
        echo "Version switch cancelled."
        exit 0
    fi
}

# Run main function with all arguments
main "$@"
