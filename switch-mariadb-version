#!/bin/bash

# MariaDB version switch script - configurable version switching
# Usage: switch-mariadb-version <source_version> <target_version>

# Package name configuration (not to be changed by user)
readonly NICE_NAME="MariaDB"
readonly PACKAGE_PREFIX="mariadb"

set -euo pipefail

# Function to display usage
usage() {
    cat << EOF
Usage: $0 <source_version> <target_version>

Examples:
  $0 10.11 11.8

Description:
  Switches ${NICE_NAME} packages shipped in the standard repositories
  of Fedora, CentOS Stream and RHEL from source version to target version.

  Lists installed packages, maps to target versions, and runs DNF install.
EOF
    exit "${1:-1}"
}

# Function to validate version format
validate_version() {
    local version="${1:-}"
    if [[ ! $version =~ ^[0-9]+\.[0-9]+$ ]]; then
        echo "Error: Version must be in format NUMBER.NUMBER (e.g., 10.11)" >&2
        exit 1
    fi
}

# Function to find source packages from rpm output
# Sets global SOURCE_PACKAGES array
find_source_packages() {
    local source_version="${1:-}"
    local rpm_output="${2:-}"
    local version_pattern="${source_version//./\\.}"

    local matched
    # Use grep with || true to avoid pipefail issues when no matches found
    matched=$(echo "$rpm_output" | grep -E "^${PACKAGE_PREFIX}.*-${version_pattern}" || true)

    if [ -z "$matched" ]; then
        echo "Error: No ${NICE_NAME} $source_version packages found installed" >&2
        exit 1
    fi

    mapfile -t SOURCE_PACKAGES < <(echo "$matched" | sort)
}

# Function to display source packages
display_source_packages() {
    local source_version="${1:-}"
    echo "Checking for ${NICE_NAME} $source_version packages..."
    echo "Found ${#SOURCE_PACKAGES[@]} ${NICE_NAME} $source_version installed packages:"
    for package in "${SOURCE_PACKAGES[@]}"; do
        echo "  $package"
    done
    echo
}

# Function to generate target package list from SOURCE_PACKAGES
generate_target_packages() {
    local source_version="${1:-}"
    local target_version="${2:-}"

    for package in "${SOURCE_PACKAGES[@]}"; do
        # Strip version suffix to get base package name
        local base_package="${package%%-"${source_version}"*}"

        local target_package
        # Check if package is versioned (starts with ${PACKAGE_PREFIX}<version>)
        if [[ $base_package =~ ^${PACKAGE_PREFIX}${source_version}(-|$) ]]; then
            # Versioned package: replace ${PACKAGE_PREFIX}<source_version> with ${PACKAGE_PREFIX}<target_version>
            target_package=${base_package/${PACKAGE_PREFIX}${source_version}/${PACKAGE_PREFIX}${target_version}}
        else
            # Unversioned package: replace ${PACKAGE_PREFIX} with ${PACKAGE_PREFIX}<target_version>
            target_package=${base_package/${PACKAGE_PREFIX}/${PACKAGE_PREFIX}${target_version}}
        fi
        printf '%s\n' "$target_package"
    done
}

# Main function
main() {
    # Check arguments
    if [ $# -ne 2 ]; then
        echo "Error: Exactly 2 arguments required" >&2
        usage
    fi

    local source_version="$1"
    local target_version="$2"

    # Check for empty arguments
    if [ -z "$source_version" ] || [ -z "$target_version" ]; then
        echo "Error: Both source and target versions must be non-empty" >&2
        usage
    fi

    echo "${NICE_NAME} Version Switch: $source_version -> $target_version"
    echo "======================================================"

    # Validate version formats
    validate_version "$source_version"
    validate_version "$target_version"

    # Query rpm once, find and display source packages
    local rpm_output
    rpm_output=$(rpm -qa 2>/dev/null)
    find_source_packages "$source_version" "$rpm_output"
    display_source_packages "$source_version"

    # Generate target package list
    local -a target_packages
    mapfile -t target_packages < <(generate_target_packages "$source_version" "$target_version")

    # Display target packages one per line
    echo "Composing list of packages to be installed:"
    for package in "${target_packages[@]}"; do
        echo "   $package"
    done
    echo
    echo "Ready to switch ${NICE_NAME} packages."
    echo
    echo "This will run:"
    echo "  dnf install --allowerasing ${target_packages[*]}"
    read -p "Continue with version switch? (y/N): " -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Starting ${NICE_NAME} version switch..."
        dnf install --allowerasing "${target_packages[@]}"
        exit $?
    else
        echo "Version switch cancelled."
        exit 1
    fi
}

# Show help if requested
if [[ $# -gt 0 && ("$1" == "-h" || "$1" == "--help") ]]; then
    usage 0
fi

# Run main function with all arguments
main "$@"
